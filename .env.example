# ============================================
# AIREPLY - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Google OAuth (for Gmail integration) ---
# Create credentials at https://console.cloud.google.com/
# Add these OAuth scopes: gmail.readonly, gmail.send (optional), userinfo.email, userinfo.profile
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- OpenAI ---
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Gmail OAuth callback — must match what you set in Google Cloud Console
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# --- Encryption (generate a random 32-char string) ---
# Used to encrypt Gmail OAuth tokens stored in the database
ENCRYPTION_SECRET=your-32-character-encryption-secret-here
